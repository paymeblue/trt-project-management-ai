# TRT PM — environment variable template
# Copy to .env.local and fill in real values. Never commit .env.local.

# Neon Postgres — connection string from Neon Console -> Project -> Connection
DATABASE_URL=

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Resend API key — Resend Dashboard -> API Keys -> Create API Key
RESEND_API_KEY=

# Resend sender — use a verified sender or 'TRT PM <onboarding@resend.dev>' for local testing
EMAIL_FROM=TRT PM <onboarding@resend.dev>

# Public base URL of the app (used in email links)
APP_URL=http://localhost:3000

# Super Admin seed credentials (used by npm run db:seed-admin only, never exposed to users)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Super Admin

# Operations seed credentials (used by npm run db:seed-operations only).
# Operations has full super-admin rights; POSITION replaces the role label in the UI.
OPERATIONS_EMAIL=
OPERATIONS_PASSWORD=
OPERATIONS_NAME=Operations
OPERATIONS_POSITION=Head of Projects

# AI / Dave Aredo — Anthropic or Ollama base URL and key
# Local: ANTHROPIC_BASE_URL=http://localhost:11434 (Ollama), ANTHROPIC_API_KEY=ollama-local-key
# Prod:  ANTHROPIC_BASE_URL=https://api.anthropic.com,  ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
LLM_MODEL_NAME=
